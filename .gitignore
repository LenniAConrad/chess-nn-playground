# Python/runtime caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Virtual environments and packaging output
.venv/
venv/
env/
build/
dist/
*.egg-info/

# Local editor/agent state
.claude/
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Local secrets
.env
.env.*
*.pem
*.key

# Training data and generated datasets
data/**
!data/
!data/README.md
!data/reports/
!data/reports/*.md
!data/reports/*.json
data/reports/environment_report.*

# Experiment outputs, checkpoints, predictions, and model artifacts
results/**
!results/
!results/README.md
*.parquet
*.pt
*.pth
*.ckpt
*.onnx
*.pkl
*.npz

# Generated report assets and run logs
logs/
reports/**/*.log
reports/**/*.png
reports/**/*.pdf
reports/**/*.html
reports/**/generated_configs/
reports/**/logs/
reports/paper_ready_all/
reports/latest/
reports/experiment_logs/
reports/flops/
reports/training/*.csv

# Temporary files
tmp/
temp/
*.tmp

# Python/runtime caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Virtual environments and packaging output
.venv/
venv/
env/
build/
dist/
*.egg-info/

# Local editor/agent state
.claude/
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Local secrets
.env
.env.*
*.pem
*.key

# Training data and generated datasets
data/**
!data/
!data/README.md
!data/reports/
!data/reports/*.md
!data/reports/*.json
data/reports/environment_report.*

# Experiment outputs, checkpoints, predictions, and model artifacts
results/**
!results/
!results/README.md
*.parquet
*.pt
*.pth
*.ckpt
*.onnx
*.pkl
*.npz

# Generated report assets and run logs
logs/
reports/**/*.log
reports/**/*.png
reports/**/*.pdf
reports/**/*.html
reports/**/generated_configs/
reports/**/logs/
reports/paper_ready_all/
reports/latest/
reports/experiment_logs/
reports/flops/
reports/training/*.csv

# Temporary files
tmp/
temp/
*.tmp

# Local working directories — large run artifacts; not for github.
_archive/
_combined_view/
_scout_combined_view/
session/
reports/tmux_logs/

# Allow paper report artifacts (overrides the broad reports/**/*.pdf ignore)
!reports/audits/paper_report.pdf
!reports/audits/paper_report_zh.pdf
!reports/audits/paper_report.tex
!reports/audits/paper_report_zh.tex
!reports/audits/puzzle_class_examples.pdf
!reports/audits/puzzle_class_examples.png
!reports/audits/scout_heatmap_pretty.png
!reports/audits/scout_heatmap_pretty.pdf
